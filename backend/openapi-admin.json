          { "name": "action", "in": "query", "schema": { "type": "string" } },
          { "name": "startTime", "in": "query", "schema": { "type": "string", "format": "date-time" } },
          { "name": "endTime", "in": "query", "schema": { "type": "string", "format": "date-time" } }
